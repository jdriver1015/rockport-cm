# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API, and Project Settings → Database)

# Postgres connection string — use the "Transaction" pooler URL from Supabase
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase client (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only key for storage uploads and admin operations — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
